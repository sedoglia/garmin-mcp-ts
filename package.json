{
  "name": "garmin-mcp-ts",
  "version": "4.1.0",
  "type": "module",
  "description": "Garmin Connect MCP Server in TypeScript with Secure Encryption",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "login": "node dist/garmin/simple-login.js",
    "dev": "tsx watch src/index.ts",
    "test": "npx tsx src/test-tools.ts",
    "test-oauth": "npx tsx src/test-oauth.ts",
    "test-keytar": "npx tsx scripts/test-keytar.ts",
    "setup-encryption": "npx tsx scripts/setup-encryption.ts",
    "check-encryption": "npx tsx scripts/check-encryption.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.18.0",
    "dotenv": "^16.3.0",
    "garmin-connect": "^1.6.2",
    "pino": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.0"
  },
  "overrides": {
    "ajv": ">=8.18.0",
    "hono": ">=4.12.25",
    "@hono/node-server": ">=2.0.5",
    "lodash": ">=4.18.1",
    "path-to-regexp": ">=8.4.2",
    "fast-uri": ">=3.1.4",
    "ip-address": ">=10.1.1",
    "follow-redirects": ">=1.16.0",
    "form-data": ">=4.0.6",
    "body-parser": ">=2.3.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.23.1",
    "typescript": "^5.3.0"
  }
}
